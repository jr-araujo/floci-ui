@model List<EcsClusterInfo>
@{
    ViewData["Title"] = "ECS";
    var taskDefs = ViewBag.TaskDefinitions as List<EcsTaskDefinitionInfo> ?? new();
}
<div class="service-header">
    <div class="service-title"><span style="color:#48dbfb">⊞</span> ECS Clusters <span class="service-count">@Model.Count total</span></div>
    <button class="btn btn--primary" onclick="openModal('createCluster')">+ Create Cluster</button>
</div>

<div class="section-title">CLUSTERS</div>
@if (Model.Count == 0)
{
    <div class="table-wrap"><div class="empty-state"><div class="empty-icon">⊞</div><div class="empty-title">No ECS clusters</div><div class="empty-sub">Create a cluster to run containerised workloads.</div></div></div>
}
else
{
    <div class="table-wrap"><table>
    <thead><tr><th>Cluster Name</th><th>Status</th><th>Running Tasks</th><th>Services</th><th>Container Instances</th><th>Actions</th></tr></thead>
    <tbody>
    @foreach (var c in Model)
    {
        <tr>
        <td class="mono">@c.ClusterName</td>
        <td><span class="badge @(c.Status=="ACTIVE"?"badge--green":"badge--yellow")">@c.Status</span></td>
        <td class="mono">@c.RunningTasksCount</td>
        <td class="mono">@c.ActiveServicesCount</td>
        <td class="mono">@c.RegisteredContainerInstancesCount</td>
        <td>
            <div class="action-row">
            <button class="btn btn--green btn--sm" onclick="openRunTaskModal('@c.ClusterArn', '@c.ClusterName')">Run Task</button>
            <form asp-action="DeleteEcsCluster" method="post" onsubmit="return confirm('Delete ECS cluster?')">
                <input type="hidden" name="arn" value="@c.ClusterArn" />
                <button type="submit" class="btn btn--danger btn--sm">Delete</button>
            </form>
            </div>
        </td>
        </tr>
    }
    </tbody></table></div>
}

<div class="section-title" style="margin-top:32px">TASK DEFINITIONS
    <button class="btn btn--primary btn--sm" style="margin-left:12px" onclick="openModal('registerTaskDef')">+ Register</button>
</div>
@if (taskDefs.Count == 0)
{
    <div class="table-wrap"><div class="empty-state"><div class="empty-icon">⊞</div><div class="empty-title">No task definitions</div></div></div>
}
else
{
    <div class="table-wrap"><table>
    <thead><tr><th>Family</th><th>Revision</th><th>Status</th><th>Network Mode</th><th>Containers</th></tr></thead>
    <tbody>
    @foreach (var td in taskDefs)
    {
        <tr>
        <td class="mono">@td.Family</td>
        <td class="mono">@td.Revision</td>
        <td><span class="badge @(td.Status=="ACTIVE"?"badge--green":"badge--yellow")">@td.Status</span></td>
        <td class="mono">@td.NetworkMode</td>
        <td class="text-dim">@string.Join(", ", td.ContainerNames)</td>
        </tr>
    }
    </tbody></table></div>
}

@section Modals {
<div class="modal-overlay" id="createCluster"><div class="modal"><div class="modal-title">Create ECS Cluster</div>
<form asp-action="CreateEcsCluster" method="post">
    <div class="form-group"><label class="form-label">Cluster Name</label><input name="ClusterName" class="form-control" required placeholder="my-cluster" /></div>
    <div class="modal-footer"><button type="button" class="btn btn--ghost" onclick="closeModal('createCluster')">Cancel</button><button type="submit" class="btn btn--primary">Create</button></div>
</form></div></div>

<div class="modal-overlay" id="registerTaskDef"><div class="modal" style="max-width:560px"><div class="modal-title">Register Task Definition</div>
<form asp-action="RegisterTaskDefinition" method="post">
    <div class="form-group"><label class="form-label">Family</label><input name="Family" class="form-control" required placeholder="my-task" /></div>
    <div class="form-group"><label class="form-label">Network Mode</label>
    <select name="NetworkMode" class="form-control"><option value="awsvpc">awsvpc</option><option value="bridge">bridge</option><option value="host">host</option></select></div>
    <div class="form-group"><label class="form-label">Container Name</label><input name="ContainerName" class="form-control" required placeholder="app" /></div>
    <div class="form-group"><label class="form-label">Container Image</label><input name="Image" class="form-control" required placeholder="nginx:latest" /></div>
    <div class="form-group"><label class="form-label">Container Port</label><input name="ContainerPort" type="number" class="form-control" value="80" /></div>
    <div class="form-group"><label class="form-label">CPU units</label><input name="Cpu" type="number" class="form-control" value="256" /></div>
    <div class="form-group"><label class="form-label">Memory (MB)</label><input name="Memory" type="number" class="form-control" value="512" /></div>
    <div class="form-group"><label class="form-label">Execution Role ARN (optional)</label><input name="ExecutionRoleArn" class="form-control mono" placeholder="arn:aws:iam::..." /></div>
    <div class="modal-footer"><button type="button" class="btn btn--ghost" onclick="closeModal('registerTaskDef')">Cancel</button><button type="submit" class="btn btn--primary">Register</button></div>
</form></div></div>

<div class="modal-overlay" id="runTask"><div class="modal"><div class="modal-title">Run Task — <span id="runTaskClusterName"></span></div>
<form asp-action="RunEcsTask" method="post">
    <input type="hidden" name="ClusterArn" id="runTaskClusterArn" />
    <input type="hidden" name="ClusterName" id="runTaskClusterNameHidden" />
    <div class="form-group"><label class="form-label">Task Definition</label>
    <select name="TaskDefinition" class="form-control">
        @foreach (var td in taskDefs) { <option value="@td.Family">@td.Family:@td.Revision</option> }
    </select></div>
    <div class="form-group"><label class="form-label">Count</label><input name="Count" type="number" class="form-control" value="1" min="1" max="10" /></div>
    <div class="form-group"><label class="form-label">Launch Type</label>
    <select name="LaunchType" class="form-control"><option value="FARGATE">FARGATE</option><option value="EC2">EC2</option></select></div>
    <div class="modal-footer"><button type="button" class="btn btn--ghost" onclick="closeModal('runTask')">Cancel</button><button type="submit" class="btn btn--green">Run Task</button></div>
</form></div></div>
}
@section Scripts {<script>
function openModal(id){document.getElementById(id).classList.add('open');}
function closeModal(id){document.getElementById(id).classList.remove('open');}
document.querySelectorAll('.modal-overlay').forEach(m=>m.addEventListener('click',e=>{if(e.target===m)m.classList.remove('open');}));
function openRunTaskModal(arn, name){
    document.getElementById('runTaskClusterArn').value=arn;
    document.getElementById('runTaskClusterName').textContent=name;
    document.getElementById('runTaskClusterNameHidden').value=name;
    openModal('runTask');
}
</script>}
