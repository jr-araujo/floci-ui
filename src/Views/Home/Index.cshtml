@model DashboardSummary
@{
    ViewData["Title"] = "Dashboard";
}

@{
    string Card(string label, string action, string icon, string colorVar, int count, string unit)
    {
        var err = count < 0;
        var val = err ? "ERR" : count.ToString();
        var cls = err ? "error" : "";
        return $@"<a href=""/Services/{action}"" class=""stat-card"">
  <div class=""stat-header""><span class=""stat-label"">{label}</span><span class=""stat-icon"" style=""color:{colorVar}"">{icon}</span></div>
  <div class=""stat-value {cls}"">{val}</div>
  <span class=""text-dim text-sm"">{unit}</span>
  <span class=""stat-accent"" style=""background:{colorVar}""></span>
</a>";
    }
}

