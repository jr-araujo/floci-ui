@model List<AthenaWorkGroupInfo>
@{ViewData["Title"] = "Athena";}
<div class="service-header">
    <div class="service-title"><span style="color:#00cec9">⊛</span> Athena Work Groups <span class="service-count">@Model.Count total</span></div>
</div>
@if (Model.Count > 0)
{
    <div class="table-wrap"><table>
    <thead><tr><th>Work Group</th><th>State</th><th>Output Location</th><th>Description</th><th>Actions</th></tr></thead>
    <tbody>
    @foreach (var wg in Model)
    {
        <tr>
        <td class="mono">@wg.Name</td>
        <td><span class="badge @(wg.State=="ENABLED"?"badge--green":"badge--yellow")">@wg.State</span></td>
        <td class="mono" style="font-size:11px">@wg.OutputLocation</td>
        <td class="text-dim">@wg.Description</td>
        <td>
            <button class="btn btn--green btn--sm" onclick="openQueryModal('@wg.Name', '@wg.OutputLocation')">Run Query</button>
        </td>
        </tr>
    }
    </tbody></table></div>
}
else
{
    <div class="table-wrap"><div class="empty-state"><div class="empty-icon">⊛</div><div class="empty-title">No work groups</div><div class="empty-sub">The primary work group is auto-created on first query.</div></div></div>
}

@if (TempData["Success"]?.ToString()?.Contains("Execution ID") == true)
{
    <div style="margin-top:20px">
        <div class="section-title">LAST QUERY</div>
        <div class="result-box">@TempData["Success"]</div>
    </div>
}

@section Modals {
<div class="modal-overlay" id="runQuery"><div class="modal" style="max-width:600px"><div class="modal-title">Run Athena Query</div>
<form asp-action="RunAthenaQuery" method="post">
    <input type="hidden" name="WorkGroup" id="queryWorkGroup" />
    <div class="form-group"><label class="form-label">Output Location (S3)</label>
    <input name="OutputLocation" id="queryOutputLocation" class="form-control mono" placeholder="s3://my-bucket/results/" /></div>
    <div class="form-group"><label class="form-label">SQL Query</label>
    <textarea name="QueryString" class="form-control mono" rows="6" required>SELECT 1</textarea></div>
    <div class="modal-footer"><button type="button" class="btn btn--ghost" onclick="closeModal('runQuery')">Cancel</button><button type="submit" class="btn btn--primary">Run</button></div>
</form></div></div>
}
@section Scripts {<script>
function openModal(id){document.getElementById(id).classList.add('open');}
function closeModal(id){document.getElementById(id).classList.remove('open');}
document.querySelectorAll('.modal-overlay').forEach(m=>m.addEventListener('click',e=>{if(e.target===m)m.classList.remove('open');}));
function openQueryModal(wg, outputLoc){
    document.getElementById('queryWorkGroup').value=wg;
    document.getElementById('queryOutputLocation').value=outputLoc||'';
    openModal('runQuery');
}
</script>}
