@model List<GlueTableInfo>
@{
    ViewData["Title"] = $"Glue — {ViewBag.DatabaseName}";
    string dbName = ViewBag.DatabaseName ?? "";
}
<div class="service-header">
    <div>
        <div class="service-title"><span style="color:#6c5ce7">⋈</span> Tables — <span class="mono">@dbName</span> <span class="service-count">@Model.Count total</span></div>
        <a asp-action="Glue" style="font-size:12px;color:var(--text-dim)">← Back to Databases</a>
    </div>
</div>
@if (Model.Count == 0)
{
    <div class="table-wrap"><div class="empty-state"><div class="empty-icon">⋈</div><div class="empty-title">No tables</div><div class="empty-sub">Tables are created by Glue crawlers or manually via SDK.</div></div></div>
}
else
{
    <div class="table-wrap"><table>
    <thead><tr><th>Table Name</th><th>Database</th><th>Table Type</th><th>Created</th></tr></thead>
    <tbody>
    @foreach (var t in Model)
    {
        <tr>
        <td class="mono">@t.Name</td>
        <td class="mono">@t.DatabaseName</td>
        <td><span class="badge badge--blue">@t.TableType</span></td>
        <td class="mono">@(t.CreateTime.HasValue ? t.CreateTime.Value.ToString("yyyy-MM-dd") : "—")</td>
        </tr>
    }
    </tbody></table></div>
}
