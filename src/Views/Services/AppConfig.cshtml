@model List<AppConfigApplicationInfo>
@{ViewData["Title"] = "AppConfig";}
<div class="service-header">
    <div class="service-title"><span style="color:#74b9ff">⊗</span> AppConfig Applications <span class="service-count">@Model.Count total</span></div>
    <button class="btn btn--primary" onclick="openModal('createApp')">+ Create Application</button>
</div>
@if (Model.Count == 0)
{
    <div class="table-wrap"><div class="empty-state"><div class="empty-icon">⊗</div><div class="empty-title">No AppConfig applications</div><div class="empty-sub">Create an AppConfig application to manage feature flags and configuration.</div></div></div>
}
else
{
    <div class="table-wrap"><table>
    <thead><tr><th>Application Name</th><th>ID</th><th>Description</th><th>Actions</th></tr></thead>
    <tbody>
    @foreach (var a in Model)
    {
        <tr>
        <td class="mono">@a.Name</td>
        <td class="mono" style="font-size:11px">@a.Id</td>
        <td class="text-dim">@a.Description</td>
        <td>
            <div class="action-row">
            <a asp-action="AppConfigEnvironments" asp-route-applicationId="@a.Id" asp-route-appName="@a.Name" class="btn btn--cyan btn--sm">Environments</a>
            <form asp-action="DeleteAppConfigApplication" method="post" onsubmit="return confirm('Delete AppConfig application?')">
                <input type="hidden" name="id" value="@a.Id" />
                <button type="submit" class="btn btn--danger btn--sm">Delete</button>
            </form>
            </div>
        </td>
        </tr>
    }
    </tbody></table></div>
}

@section Modals {
<div class="modal-overlay" id="createApp"><div class="modal"><div class="modal-title">Create AppConfig Application</div>
<form asp-action="CreateAppConfigApplication" method="post">
    <div class="form-group"><label class="form-label">Name</label><input name="Name" class="form-control" required placeholder="my-app" /></div>
    <div class="form-group"><label class="form-label">Description</label><input name="Description" class="form-control" placeholder="Optional description" /></div>
    <div class="modal-footer"><button type="button" class="btn btn--ghost" onclick="closeModal('createApp')">Cancel</button><button type="submit" class="btn btn--primary">Create</button></div>
</form></div></div>
}
@section Scripts {<script>
function openModal(id){document.getElementById(id).classList.add('open');}
function closeModal(id){document.getElementById(id).classList.remove('open');}
document.querySelectorAll('.modal-overlay').forEach(m=>m.addEventListener('click',e=>{if(e.target===m)m.classList.remove('open');}));
</script>}
