@model List<LoadBalancerInfo>
@{
    ViewData["Title"] = "Elastic Load Balancing v2";
    var targetGroups = ViewBag.TargetGroups as List<TargetGroupInfo> ?? new();
}
<div class="service-header">
    <div class="service-title"><span style="color:#6c5ce7">⊴</span> ELB v2 <span class="service-count">@Model.Count load balancers</span></div>
</div>

<div class="section-title">LOAD BALANCERS</div>
@if (Model.Count == 0)
{
    <div class="table-wrap"><div class="empty-state"><div class="empty-icon">⊴</div><div class="empty-title">No load balancers</div></div></div>
}
else
{
    <div class="table-wrap"><table>
    <thead><tr><th>Name</th><th>Type</th><th>Scheme</th><th>State</th><th>DNS Name</th><th>Created</th><th>Actions</th></tr></thead>
    <tbody>
    @foreach (var lb in Model)
    {
        <tr>
        <td class="mono">@lb.LoadBalancerName</td>
        <td><span class="badge badge--cyan">@lb.Type</span></td>
        <td class="mono">@lb.Scheme</td>
        <td><span class="badge @(lb.State=="active"?"badge--green":"badge--yellow")">@lb.State</span></td>
        <td><span class="mono" style="font-size:11px">@lb.DNSName</span></td>
        <td class="mono">@lb.CreatedTime.ToString("yyyy-MM-dd")</td>
        <td>
            <form asp-action="DeleteLoadBalancer" method="post" onsubmit="return confirm('Delete load balancer?')">
                <input type="hidden" name="arn" value="@lb.LoadBalancerArn" />
                <button type="submit" class="btn btn--danger btn--sm">Delete</button>
            </form>
        </td>
        </tr>
    }
    </tbody></table></div>
}

<div class="section-title" style="margin-top:32px">TARGET GROUPS
    <button class="btn btn--primary btn--sm" style="margin-left:12px" onclick="openModal('createTg')">+ Create</button>
</div>
@if (targetGroups.Count == 0)
{
    <div class="table-wrap"><div class="empty-state"><div class="empty-icon">⊴</div><div class="empty-title">No target groups</div></div></div>
}
else
{
    <div class="table-wrap"><table>
    <thead><tr><th>Name</th><th>Protocol</th><th>Port</th><th>Target Type</th><th>VPC</th><th>Actions</th></tr></thead>
    <tbody>
    @foreach (var tg in targetGroups)
    {
        <tr>
        <td class="mono">@tg.TargetGroupName</td>
        <td><span class="badge badge--blue">@tg.Protocol</span></td>
        <td class="mono">@tg.Port</td>
        <td class="mono">@tg.TargetType</td>
        <td class="mono">@tg.VpcId</td>
        <td>
            <form asp-action="DeleteTargetGroup" method="post" onsubmit="return confirm('Delete target group?')">
                <input type="hidden" name="arn" value="@tg.TargetGroupArn" />
                <button type="submit" class="btn btn--danger btn--sm">Delete</button>
            </form>
        </td>
        </tr>
    }
    </tbody></table></div>
}

@section Modals {
<div class="modal-overlay" id="createTg"><div class="modal"><div class="modal-title">Create Target Group</div>
<form asp-action="CreateTargetGroup" method="post">
    <div class="form-group"><label class="form-label">Name</label><input name="Name" class="form-control" required placeholder="my-targets" /></div>
    <div class="form-group"><label class="form-label">Protocol</label>
    <select name="Protocol" class="form-control"><option value="HTTP">HTTP</option><option value="HTTPS">HTTPS</option><option value="TCP">TCP</option></select></div>
    <div class="form-group"><label class="form-label">Port</label><input name="Port" type="number" class="form-control" value="80" /></div>
    <div class="form-group"><label class="form-label">Target Type</label>
    <select name="TargetType" class="form-control"><option value="ip">ip</option><option value="instance">instance</option><option value="lambda">lambda</option></select></div>
    <div class="form-group"><label class="form-label">VPC ID (optional)</label><input name="VpcId" class="form-control mono" placeholder="vpc-xxxxxxxx" /></div>
    <div class="modal-footer"><button type="button" class="btn btn--ghost" onclick="closeModal('createTg')">Cancel</button><button type="submit" class="btn btn--primary">Create</button></div>
</form></div></div>
}
@section Scripts {<script>
function openModal(id){document.getElementById(id).classList.add('open');}
function closeModal(id){document.getElementById(id).classList.remove('open');}
document.querySelectorAll('.modal-overlay').forEach(m=>m.addEventListener('click',e=>{if(e.target===m)m.classList.remove('open');}));
</script>}
