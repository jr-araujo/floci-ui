@model List<IamUserInfo>
@{ViewData["Title"] = "IAM — Users & Roles";
  var roles = ViewBag.Roles as List<IamRoleInfo> ?? new();}
<div class="service-header">
    <div class="service-title"><span style="color:var(--iam)">👤</span> IAM Users <span class="service-count">@Model.Count users</span></div>
    <div class="action-row">
        <button class="btn btn--primary" onclick="openModal(''createUser'')">+ Create User</button>
        <button class="btn btn--blue" onclick="openModal(''createRole'')">+ Create Role</button>
    </div>
</div>
<div class="section-title">USERS</div>
@if (Model.Count == 0) { <div class="table-wrap"><div class="empty-state"><div class="empty-icon">👤</div><div class="empty-title">No users yet</div></div></div>
} else {
<div class="table-wrap"><table>
<thead><tr><th>Username</th><th>User ID</th><th>Path</th><th>Created</th><th>ARN</th><th>Actions</th></tr></thead>
<tbody>@foreach(var u in Model){<tr>
<td class="mono">@u.UserName</td><td class="mono text-dim">@u.UserId</td><td class="mono text-dim">@u.Path</td>
<td class="mono">@u.CreateDate.ToString("yyyy-MM-dd")</td>
<td><span class="arn">@u.Arn</span></td>
<td><form asp-action="DeleteUser" method="post" onsubmit="return confirm(''Delete user \''@u.UserName\''?'')">
    <input type="hidden" name="userName" value="@u.UserName" /><button type="submit" class="btn btn--danger btn--sm">Delete</button>
</form></td>
</tr>}</tbody></table></div>
}
<div class="section-title" style="margin-top:24px">ROLES</div>
@if (roles.Count == 0) { <div class="table-wrap"><div class="empty-state"><div class="empty-icon">🎭</div><div class="empty-title">No roles yet</div></div></div>
} else {
<div class="table-wrap"><table>
<thead><tr><th>Role Name</th><th>Role ID</th><th>Created</th><th>ARN</th><th>Actions</th></tr></thead>
<tbody>@foreach(var r in roles){<tr>
<td class="mono">@r.RoleName</td><td class="mono text-dim">@r.RoleId</td>
<td class="mono">@r.CreateDate.ToString("yyyy-MM-dd")</td>
<td><span class="arn">@r.Arn</span></td>
<td><form asp-action="DeleteRole" method="post" onsubmit="return confirm(''Delete role \''@r.RoleName\''?'')">
    <input type="hidden" name="roleName" value="@r.RoleName" /><button type="submit" class="btn btn--danger btn--sm">Delete</button>
</form></td>
</tr>}</tbody></table></div>
}
@section Modals {
<div class="modal-overlay" id="createUser"><div class="modal"><div class="modal-title">Create IAM User</div>
<form asp-action="CreateUser" method="post">
    <div class="form-group"><label class="form-label">Username</label><input name="UserName" class="form-control" required /></div>
    <div class="form-group"><label class="form-label">Path</label><input name="Path" class="form-control" value="/" /></div>
    <div class="modal-footer"><button type="button" class="btn btn--ghost" onclick="closeModal(''createUser'')">Cancel</button>
    <button type="submit" class="btn btn--primary">Create</button></div>
</form></div></div>
<div class="modal-overlay" id="createRole"><div class="modal" style="max-width:560px"><div class="modal-title">Create IAM Role</div>
<form asp-action="CreateRole" method="post">
    <div class="form-group"><label class="form-label">Role Name</label><input name="RoleName" class="form-control" required /></div>
    <div class="form-group"><label class="form-label">Assume Role Policy Document (JSON)</label>
    <textarea name="AssumeRolePolicyDocument" class="form-control mono" rows="6" required>{"Version":"2012-10-17","Statement":[{"Effect":"Allow","Principal":{"Service":"lambda.amazonaws.com"},"Action":"sts:AssumeRole"}]}</textarea></div>
    <div class="modal-footer"><button type="button" class="btn btn--ghost" onclick="closeModal(''createRole'')">Cancel</button>
    <button type="submit" class="btn btn--primary">Create</button></div>
</form></div></div>
}
@section Scripts {<script>
function openModal(id){document.getElementById(id).classList.add(''open'');}
function closeModal(id){document.getElementById(id).classList.remove(''open'');}
document.querySelectorAll(''.modal-overlay'').forEach(m=>m.addEventListener(''click'',e=>{if(e.target===m)m.classList.remove(''open'');}));
</script>}