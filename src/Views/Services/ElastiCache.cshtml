@model List<ElastiCacheClusterInfo>
@{ViewData["Title"] = "ElastiCache";}
<div class="service-header">
    <div class="service-title"><span style="color:#c05de9">⊡</span> ElastiCache <span class="service-count">@Model.Count clusters</span></div>
    <button class="btn btn--primary" onclick="openModal('createCluster')">+ Create Cluster</button>
</div>
@if (Model.Count == 0)
{
    <div class="table-wrap"><div class="empty-state"><div class="empty-icon">⊡</div><div class="empty-title">No cache clusters</div><div class="empty-sub">Create Redis or Memcached clusters for in-memory caching.</div></div></div>
}
else
{
    <div class="table-wrap"><table>
    <thead><tr><th>Cluster ID</th><th>Engine</th><th>Version</th><th>Node Type</th><th>Nodes</th><th>Status</th><th>Actions</th></tr></thead>
    <tbody>
    @foreach (var c in Model)
    {
        <tr>
        <td class="mono">@c.ClusterId</td>
        <td><span class="badge badge--purple">@c.Engine</span></td>
        <td class="mono">@c.EngineVersion</td>
        <td class="mono">@c.CacheNodeType</td>
        <td class="mono">@c.NumCacheNodes</td>
        <td><span class="badge @(c.Status=="available"?"badge--green":"badge--yellow")">@c.Status</span></td>
        <td>
            <form asp-action="DeleteCacheCluster" method="post" onsubmit="return confirm('Delete cluster?')">
                <input type="hidden" name="clusterId" value="@c.ClusterId" />
                <button type="submit" class="btn btn--danger btn--sm">Delete</button>
            </form>
        </td>
        </tr>
    }
    </tbody></table></div>
}

@section Modals {
<div class="modal-overlay" id="createCluster"><div class="modal"><div class="modal-title">Create Cache Cluster</div>
<form asp-action="CreateCacheCluster" method="post">
    <div class="form-group"><label class="form-label">Cluster ID</label><input name="ClusterId" class="form-control" required placeholder="my-redis" /></div>
    <div class="form-group"><label class="form-label">Engine</label>
    <select name="Engine" class="form-control"><option value="redis">Redis</option><option value="memcached">Memcached</option></select></div>
    <div class="form-group"><label class="form-label">Engine Version</label><input name="EngineVersion" class="form-control" value="7.0" /></div>
    <div class="form-group"><label class="form-label">Node Type</label>
    <select name="CacheNodeType" class="form-control">
        <option value="cache.t3.micro">cache.t3.micro</option>
        <option value="cache.t3.small">cache.t3.small</option>
        <option value="cache.t3.medium">cache.t3.medium</option>
        <option value="cache.r6g.large">cache.r6g.large</option>
    </select></div>
    <div class="form-group"><label class="form-label">Number of Nodes</label><input name="NumCacheNodes" type="number" class="form-control" value="1" min="1" max="20" /></div>
    <div class="modal-footer"><button type="button" class="btn btn--ghost" onclick="closeModal('createCluster')">Cancel</button><button type="submit" class="btn btn--primary">Create</button></div>
</form></div></div>
}
@section Scripts {<script>
function openModal(id){document.getElementById(id).classList.add('open');}
function closeModal(id){document.getElementById(id).classList.remove('open');}
document.querySelectorAll('.modal-overlay').forEach(m=>m.addEventListener('click',e=>{if(e.target===m)m.classList.remove('open');}));
</script>}
