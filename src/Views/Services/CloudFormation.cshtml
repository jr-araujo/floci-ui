@model List<CloudFormationStackInfo>
@{ViewData["Title"] = "CloudFormation";}
<div class="service-header">
    <div class="service-title"><span style="color:#e17055">⊞</span> CloudFormation <span class="service-count">@Model.Count stacks</span></div>
    <button class="btn btn--primary" onclick="openModal('createStack')">+ Create Stack</button>
</div>
@if (Model.Count == 0)
{
    <div class="table-wrap"><div class="empty-state"><div class="empty-icon">⊞</div><div class="empty-title">No stacks</div><div class="empty-sub">Deploy CloudFormation stacks to provision AWS resources.</div></div></div>
}
else
{
    <div class="table-wrap"><table>
    <thead><tr><th>Stack Name</th><th>Status</th><th>Created</th><th>Description</th><th>Actions</th></tr></thead>
    <tbody>
    @foreach (var s in Model)
    {
        <tr>
        <td class="mono">@s.StackName</td>
        <td><span class="badge @(s.Status.Contains("COMPLETE")?"badge--green":s.Status.Contains("FAIL")?"badge--red":"badge--yellow")">@s.Status</span></td>
        <td class="mono">@s.CreationTime.ToString("yyyy-MM-dd HH:mm")</td>
        <td class="text-dim">@s.Description</td>
        <td>
            <form asp-action="DeleteStack" method="post" onsubmit="return confirm('Delete stack?')">
                <input type="hidden" name="name" value="@s.StackName" />
                <button type="submit" class="btn btn--danger btn--sm">Delete</button>
            </form>
        </td>
        </tr>
    }
    </tbody></table></div>
}

@section Modals {
<div class="modal-overlay" id="createStack"><div class="modal" style="max-width:600px"><div class="modal-title">Create Stack</div>
<form asp-action="CreateStack" method="post">
    <div class="form-group"><label class="form-label">Stack Name</label><input name="StackName" class="form-control" required placeholder="my-stack" /></div>
    <div class="form-group"><label class="form-label">Template Body (JSON/YAML)</label>
    <textarea name="TemplateBody" class="form-control mono" rows="10" required>{"AWSTemplateFormatVersion":"2010-09-09","Resources":{"MyBucket":{"Type":"AWS::S3::Bucket"}}}</textarea></div>
    <div class="modal-footer"><button type="button" class="btn btn--ghost" onclick="closeModal('createStack')">Cancel</button><button type="submit" class="btn btn--primary">Create</button></div>
</form></div></div>
}
@section Scripts {<script>
function openModal(id){document.getElementById(id).classList.add('open');}
function closeModal(id){document.getElementById(id).classList.remove('open');}
document.querySelectorAll('.modal-overlay').forEach(m=>m.addEventListener('click',e=>{if(e.target===m)m.classList.remove('open');}));
</script>}
