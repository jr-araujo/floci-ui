@model List<S3BucketInfo>
@{
    ViewData["Title"] = "S3 — Buckets";
}

<div class="service-header">
    <div class="service-title">
        <span style="color:var(--s3)">▣</span>
        S3 Buckets
        <span class="service-count">@Model.Count total</span>
    </div>
    <button class="btn btn--primary" onclick="openModal('createBucket')">+ Create Bucket</button>
</div>

@if (Model.Count == 0)
{
    <div class="table-wrap">
        <div class="empty-state">
            <div class="empty-icon">▣</div>
            <div class="empty-title">No buckets yet</div>
            <div class="empty-sub">Create your first S3 bucket to get started</div>
        </div>
    </div>
}
else
{
    <div class="table-wrap">
        <table>
            <thead>
                <tr>
                    <th>Bucket Name</th>
                    <th>Objects</th>
                    <th>Size</th>
                    <th>Created</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var b in Model)
                {
                    <tr>
                        <td>
                            <a asp-action="S3Objects" asp-route-bucket="@b.Name" class="btn btn--ghost btn--sm">
                                📁 @b.Name
                            </a>
                        </td>
                        <td class="mono">@(b.ObjectCount < 0 ? "—" : b.ObjectCount.ToString())</td>
                        <td class="mono">@b.FormattedSize</td>
                        <td class="text-dim mono">@b.CreationDate.ToString("yyyy-MM-dd")</td>
                        <td>
                            <div class="action-row">
                                <a asp-action="S3Objects" asp-route-bucket="@b.Name" class="btn btn--ghost btn--sm">Browse</a>
                                <form asp-action="DeleteBucket" method="post" onsubmit="return confirm('Delete bucket \'@b.Name\'? This cannot be undone.')">
                                    <input type="hidden" name="name" value="@b.Name" />
                                    <button type="submit" class="btn btn--danger btn--sm">Delete</button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

@section Modals {
<div class="modal-overlay" id="createBucket">
    <div class="modal">
        <div class="modal-title">Create S3 Bucket</div>
        <form asp-action="CreateBucket" method="post">
            <div class="form-group">
                <label class="form-label">Bucket Name</label>
                <input name="BucketName" class="form-control" placeholder="my-bucket" required />
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn--ghost" onclick="closeModal('createBucket')">Cancel</button>
                <button type="submit" class="btn btn--primary">Create</button>
            </div>
        </form>
    </div>
</div>
}

@section Scripts {
<script>
function openModal(id) { document.getElementById(id).classList.add('open'); }
function closeModal(id) { document.getElementById(id).classList.remove('open'); }
document.querySelectorAll('.modal-overlay').forEach(m => m.addEventListener('click', e => { if(e.target===m) m.classList.remove('open'); }));
</script>
}
