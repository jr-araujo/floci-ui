@model List<HostedZoneInfo>
@{ViewData["Title"] = "Route 53";}
<div class="service-header">
    <div class="service-title"><span style="color:#e84393">⊕</span> Route 53 Hosted Zones <span class="service-count">@Model.Count total</span></div>
    <button class="btn btn--primary" onclick="openModal('createZone')">+ Create Hosted Zone</button>
</div>
@if (Model.Count == 0)
{
    <div class="table-wrap"><div class="empty-state"><div class="empty-icon">⊕</div><div class="empty-title">No hosted zones</div><div class="empty-sub">Create a hosted zone to manage DNS records for a domain.</div></div></div>
}
else
{
    <div class="table-wrap"><table>
    <thead><tr><th>Zone Name</th><th>Type</th><th>Record Sets</th><th>Comment</th><th>Zone ID</th><th>Actions</th></tr></thead>
    <tbody>
    @foreach (var z in Model)
    {
        <tr>
        <td class="mono">@z.Name</td>
        <td><span class="badge @(z.PrivateZone?"badge--purple":"badge--blue")">@(z.PrivateZone?"Private":"Public")</span></td>
        <td class="mono">@z.ResourceRecordSetCount</td>
        <td class="text-dim">@z.Comment</td>
        <td class="mono" style="font-size:11px">@z.Id</td>
        <td>
            <form asp-action="DeleteHostedZone" method="post" onsubmit="return confirm('Delete hosted zone?')">
                <input type="hidden" name="id" value="@z.Id" />
                <button type="submit" class="btn btn--danger btn--sm">Delete</button>
            </form>
        </td>
        </tr>
    }
    </tbody></table></div>
}

@section Modals {
<div class="modal-overlay" id="createZone"><div class="modal"><div class="modal-title">Create Hosted Zone</div>
<form asp-action="CreateHostedZone" method="post">
    <div class="form-group"><label class="form-label">Domain Name</label><input name="Name" class="form-control" required placeholder="example.com" /></div>
    <div class="form-group"><label class="form-check"><input type="checkbox" name="PrivateZone" value="true" /> Private Hosted Zone</label></div>
    <div class="form-group"><label class="form-label">Comment (optional)</label><input name="Comment" class="form-control" placeholder="Managed by Floci" /></div>
    <div class="modal-footer"><button type="button" class="btn btn--ghost" onclick="closeModal('createZone')">Cancel</button><button type="submit" class="btn btn--primary">Create</button></div>
</form></div></div>
}
@section Scripts {<script>
function openModal(id){document.getElementById(id).classList.add('open');}
function closeModal(id){document.getElementById(id).classList.remove('open');}
document.querySelectorAll('.modal-overlay').forEach(m=>m.addEventListener('click',e=>{if(e.target===m)m.classList.remove('open');}));
</script>}
