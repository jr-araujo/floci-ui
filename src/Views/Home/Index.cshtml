<div class="section-title">CONNECTION INFO</div>
<div class="info-grid">
    <div class="info-card">
        <div class="info-card-title">ENDPOINT</div>
        <div class="info-card-val mono">@ViewBag.FlociEndpoint</div>
    </div>
    <div class="info-card">
        <div class="info-card-title">REGION</div>
        <div class="info-card-val mono">@(ViewBag.CurrentRegion ?? "us-east-1")</div>
    </div>
    <div class="info-card">
        <div class="info-card-title">LAST REFRESHED</div>
        <div class="info-card-val mono">@Model.LastRefreshed.ToString("yyyy-MM-dd HH:mm:ss") UTC</div>
    </div>
    <div class="info-card">
        <div class="info-card-title">EMULATOR</div>
        <div class="info-card-val">Floci — AWS Local Emulator</div>
    </div>
</div>

@if (ViewBag.Error != null)
{
    <div class="alert alert--error">
        <span>✕</span> Could not connect to Floci at <strong>@ViewBag.FlociEndpoint</strong>: @ViewBag.Error
    </div>
}

