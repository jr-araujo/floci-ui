@model List<SecretInfo>
@{ViewData["Title"] = "Secrets Manager";}
<div class="service-header">
    <div class="service-title"><span style="color:#fd79a8">🔐</span> Secrets <span class="service-count">@Model.Count total</span></div>
    <button class="btn btn--primary" onclick="openModal(''createSecret'')">+ Create Secret</button>
</div>
@if (TempData["SecretValue"] != null) {
    <div class="alert alert--success" style="word-break:break-all"><strong>@TempData["SecretName"]</strong>: <span class="mono">@TempData["SecretValue"]</span></div>
}
@if (Model.Count == 0) {
    <div class="table-wrap"><div class="empty-state"><div class="empty-icon">🔐</div><div class="empty-title">No secrets yet</div><div class="empty-sub">Store credentials and API keys securely</div></div></div>
} else {
<div class="table-wrap"><table>
<thead><tr><th>Name</th><th>Description</th><th>Last Changed</th><th>KMS Key</th><th>ARN</th><th>Actions</th></tr></thead>
<tbody>@foreach(var s in Model){<tr>
<td class="mono">@s.Name</td>
<td class="text-dim">@s.Description</td>
<td class="mono">@s.LastChangedDate?.ToString("yyyy-MM-dd HH:mm")</td>
<td class="mono text-dim" style="font-size:11px">@(string.IsNullOrWhiteSpace(s.KmsKeyId)?"aws/secretsmanager":s.KmsKeyId)</td>
<td><span class="arn">@s.Arn</span></td>
<td><div class="action-row">
    <a asp-action="GetSecretValue" asp-route-name="@s.Name" class="btn btn--blue btn--sm">Reveal</a>
    <form asp-action="DeleteSecret" method="post" onsubmit="return confirm(''Delete secret \''@s.Name\''?'')">
        <input type="hidden" name="name" value="@s.Name" /><button type="submit" class="btn btn--danger btn--sm">Delete</button>
    </form>
</div></td>
</tr>}</tbody></table></div>
}
@section Modals {
<div class="modal-overlay" id="createSecret"><div class="modal" style="max-width:520px">
    <div class="modal-title">Create Secret</div>
    <form asp-action="CreateSecret" method="post">
        <div class="form-group"><label class="form-label">Secret Name</label><input name="Name" class="form-control" placeholder="prod/app/db" required /></div>
        <div class="form-group"><label class="form-label">Secret Value (JSON or plain string)</label>
        <textarea name="SecretString" class="form-control mono" rows="5" placeholder=''{"username":"admin","password":"secret"}'' required></textarea></div>
        <div class="form-group"><label class="form-label">Description (optional)</label><input name="Description" class="form-control" /></div>
        <div class="form-group"><label class="form-label">KMS Key ID (optional, leave empty for default)</label><input name="KmsKeyId" class="form-control mono" placeholder="arn:aws:kms:..." /></div>
        <div class="modal-footer">
            <button type="button" class="btn btn--ghost" onclick="closeModal(''createSecret'')">Cancel</button>
            <button type="submit" class="btn btn--primary">Create</button>
        </div>
    </form>
</div></div>
}
@section Scripts {<script>
function openModal(id){document.getElementById(id).classList.add(''open'');}
function closeModal(id){document.getElementById(id).classList.remove(''open'');}
document.querySelectorAll(''.modal-overlay'').forEach(m=>m.addEventListener(''click'',e=>{if(e.target===m)m.classList.remove(''open'');}));
</script>}